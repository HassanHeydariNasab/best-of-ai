[
{{ $tools := where .Site.RegularPages "Section" "tools" -}}
{{ $items := slice -}}
{{ range $tools -}}
  {{ $p := .Params -}}
  {{ $item := dict
    "name"        ($p.name        | default .Title)
    "slug"        ($p.slug        | default .File.BaseFileName)
    "url"         .RelPermalink
    "website"     ($p.website      | default "")
    "description" ($p.description | default "")
    "category"    ($p.category_name | default "")
    "price"       ($p.price       | default "Free")
  -}}
  {{ $items = $items | append $item -}}
{{ end -}}
{{ range $i, $item := $items -}}
{{ $item | jsonify }}{{ if lt $i (sub (len $items) 1) }},{{ end }}
{{ end -}}
]
